{
  "permissions": {
    "allow": [
      "Read:*",
      "Write:*",
      "Edit:*",
      "Bash:*",
      "Glob:*",
      "Grep:*",
      "Agent:*",
      "WebSearch",
      "WebFetch:*",
      "Skill:*",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "NotebookEdit:*",
      "SendMessage:*",
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__producthunt__search_posts",
      "mcp__producthunt__get_post"
    ],
    "deny": [
      "Read:.env*",
      "Bash:sudo*",
      "Bash:rm -rf /*",
      "Bash:git push --force*",
      "Bash:hatch publish*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/soh/working/agent-wall/.claude/hooks/lint.sh 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Linting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/soh/working/agent-wall/.claude/hooks/pre-stop-gate.sh"
          }
        ]
      }
    ]
  }
}
